# Public domain or dedicated public IPv4 address used to open the app
SITE_ADDRESS=app.example.com

# domain_tls for a domain; ip_tls for a bare public IPv4 address
TLS_MODE=domain_tls

# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
ENABLE_STAGE1_HARNESS=0
CLIENT_DIST_PATH=./client/dist

# Persistent data
DATABASE_PATH=./data/place-app.sqlite
MEDIA_PATH=./media

# Demo operator
ADMIN_PASSWORD=replace-with-a-long-password
FORCE_PLACE_ID=faculty-data-decision-sciences

# Local HTTPS (leave empty for plain HTTP)
TLS_KEY_PATH=
TLS_CERT_PATH=

# React/Vite LAN HTTPS development only
DEV_TLS_KEY_PATH=
DEV_TLS_CERT_PATH=
DEV_API_TARGET=http://127.0.0.1:3000

# Protocol timing defaults from SPEC.md
PRESENCE_GRACE_MS=60000
PRESENCE_BROADCAST_MS=1000
HEARTBEAT_INTERVAL_MS=30000
HEARTBEAT_MISS_LIMIT=2
WS_AUTH_TIMEOUT_MS=10000
