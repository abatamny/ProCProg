{
  "name": "place-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Place-based social web app demo",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch server/src/index.js",
    "dev:server": "node --watch server/src/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "build:client": "vite build --config client/vite.config.js",
    "preview:client": "vite preview --config client/vite.config.js",
    "start": "node server/src/index.js",
    "test": "node --test --test-concurrency=1",
    "test:stage1": "node --test --test-concurrency=1"
  },
  "dependencies": {
    "@fastify/static": "9.1.3",
    "@fontsource/inter": "5.1.1",
    "@fontsource/space-grotesk": "5.1.1",
    "@turf/boolean-point-in-polygon": "7.3.5",
    "@turf/helpers": "7.3.5",
    "better-sqlite3": "11.10.0",
    "dotenv": "17.4.2",
    "fastify": "5.10.0",
    "lucide-react": "0.468.0",
    "p-queue": "9.3.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "0.35.3",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "vite": "6.4.3"
  }
}
